PORT=5000
MONGO_URI=mongodb://localhost:27017/tracksecure
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Email alerts (optional — leave blank to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_FROM_EMAIL=alerts@tracksecure.co.ke

# SMS alerts via Africa's Talking (optional — leave blank to disable)
AT_USERNAME=
AT_API_KEY=

# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGIN=http://localhost:5500,http://localhost:3000
